# 服务器端口
PORT=3000

# SQLite配置
SQLITE_PATH=./server/data/easyssh.sqlite

# 环境设置
NODE_ENV=development

# 日志级别
LOG_LEVEL=info

# JWT密钥
JWT_SECRET=easyssh-jwt-secret-key-change-in-production
JWT_EXPIRES=86400

# 敏感数据加密密钥
ENCRYPTION_KEY=easyssh-encryption-key-change-in-production

# 性能调优
NODE_CACHE_TTL=3600
NODE_CACHE_CHECK_PERIOD=600 