# ==========================================================
# EasySSH 环境变量示例（复制为 .env 后按需修改）
# ==========================================================

# 运行模式
# - development：开发
# - production：生产
ENV=production

# ----------------------------------------------------------
# 端口与服务地址
# ----------------------------------------------------------
# 前端开发端口（scripts/dev.sh 启动时使用）
WEB_PORT=3000

# 后端服务地址（开发环境前端请求；Go 后端监听端口会从这里解析）
BACKEND_URL=http://localhost:8520

# Vite 前端开发模式请求后端的地址
VITE_BACKEND_URL=http://localhost:8520

# ----------------------------------------------------------
# 安全与 Cookie（Bearer + Refresh Cookie）
# ----------------------------------------------------------
# JWT 密钥（请务必替换为强随机值）
# 生产环境必须替换，当前值只是可被程序识别并拒绝的占位符。生成方式：openssl rand -base64 48
JWT_SECRET=easyssh-secret-change-in-production

# 加密密钥，用于敏感数据保护（包括 2FA secret 加密与备份码 HMAC）
# 生产环境必须替换，当前值只是可被程序识别并拒绝的占位符。生成方式：openssl rand -base64 32
ENCRYPTION_KEY=ZWFzeXNzaC1lbmNyeXB0aW9uLWtleS0zMmJ5dGVzISE=

# Cookie 安全策略
# - COOKIE_SECURE：HTTPS 环境必须 true；HTTP 开发环境必须 false
# - COOKIE_DOMAIN：Cookie 域名（多子域共享时设置为 .example.com），留空表示当前域
# - COOKIE_SAMESITE：lax | none | strict
#   • 同源/同站：lax（推荐）
#   • 跨域直连：none（必须搭配 HTTPS，即 COOKIE_SECURE=true）
COOKIE_SECURE=true
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# ----------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------
# 默认使用 SQLite，适合个人/小团队单实例部署。
# 可选：sqlite | postgres（也兼容 pgsql/postgresql）| mysql
DB_DRIVER=sqlite
DB_DSN=./data/easyssh.db

# 外部 PostgreSQL 示例：
# DB_DRIVER=postgres
# DB_DSN="postgres://easyssh:${DB_PASSWORD:-easyssh_password}@localhost:5432/easyssh_db?sslmode=disable"
#
# 外部 MySQL 示例：
# DB_DRIVER=mysql
# DB_DSN="mysql://easyssh:${DB_PASSWORD:-easyssh_password}@localhost:3306/easyssh_db?charset=utf8mb4&parseTime=true"

# 外部数据库连接池参数（SQLite 模式下 MaxIdle/MaxOpen 会自动收敛为 1）
# DB_MAX_IDLE_CONNS=10
# DB_MAX_OPEN_CONNS=100
# DB_CONN_MAX_LIFETIME=60
# DB_CONN_MAX_IDLE_TIME=10

# ----------------------------------------------------------
# 可选高级配置
# ----------------------------------------------------------
# 版本更新清单地址；不设置时读取 GitHub Release latest 里的 release-manifest.json
# EASYSSH_UPDATE_MANIFEST_URL=https://github.com/shan-hee/EasySSH/releases/latest/download/release-manifest.json

# 自定义 Content-Security-Policy；不设置时使用内置默认策略
# CONTENT_SECURITY_POLICY=

# 前端 WebSocket Host 覆盖；通常不需要，特殊反向代理或分离部署时再设置
# VITE_WS_HOST=
