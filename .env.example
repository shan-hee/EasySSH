# 复制为 .env；SQLite 本地启动只需要保留默认值。

# development 可直接本地运行；公网部署改为 production。
ENV=development

# 可选显式部署根密钥。留空时首次启动会安全生成到数据目录/easyssh-root.key。
# 外部数据库多实例部署必须让所有实例使用同一值：openssl rand -base64 32
ENCRYPTION_KEY=

# 数据库。SQLite 默认路径适合单实例部署。
DB_DRIVER=sqlite
DB_DSN=./data/easyssh.db

# 仅开发或自定义监听时需要；不填写均使用下列默认值。
BACKEND_URL=http://localhost:8520
WEB_PORT=3000
VITE_BACKEND_URL=http://localhost:8520

# 外部数据库按需调整；账号密码直接属于 DSN。
# DB_DRIVER=postgres
# DB_DSN=postgres://easyssh:password@db:5432/easyssh?sslmode=require
# DB_DRIVER=mysql
# DB_DSN="mysql://easyssh:password@db:3306/easyssh?charset=utf8mb4&parseTime=true"

# 仅外部数据库高负载场景需要覆盖连接池默认值。
# DB_MAX_IDLE_CONNS=10
# DB_MAX_OPEN_CONNS=100
# DB_CONN_MAX_LIFETIME=60
# DB_CONN_MAX_IDLE_TIME=10

# 可选运维覆盖：自定义版本更新清单；留空使用 GitHub Release。
# EASYSSH_UPDATE_MANIFEST_URL=https://github.com/shan-hee/EasySSH/releases/latest/download/release-manifest.json
