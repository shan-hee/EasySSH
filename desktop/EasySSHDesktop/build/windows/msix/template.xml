<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="EasySSH.exe"
        Arguments=""
        InstallLocation="C:\Program Files\EasySSH\EasySSH">
    </Installer>
    <PackageInformation
        PackageName="io.easyssh.desktop"
        PackageDisplayName="EasySSH"
        PublisherName="CN=EasySSH"
        PublisherDisplayName="EasySSH"
        Version="1.0.14.0"
        PackageDescription="Cross-platform SSH/SFTP workspace">
        <Capabilities>
            <Capability Name="runFullTrust" />

        </Capabilities>
        <Applications>
            <Application
                Id="EasySSH"
                Description="Cross-platform SSH/SFTP workspace"
                DisplayName="EasySSH"
                ExecutableName="EasySSH.exe"
                EntryPoint="Windows.FullTrustApplication">

            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>EasySSH</DisplayName>
            <PublisherDisplayName>EasySSH</PublisherDisplayName>
            <Description>Cross-platform SSH/SFTP workspace</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="EasySSH-86.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
